<div class="app-topbar d-flex align-items-center px-3">
  <div class="d-flex align-items-center gap-2">
    <span class="badge-dot">
      <span class="dot"></span>
      <span class="text-muted small">Lab Online</span>
    </span>
  </div>

  <div class="ms-auto d-flex align-items-center gap-2">
    <% if (user) { %>
      <div class="text-end me-2">
        <div class="small text-muted">Signed in</div>
        <div class="fw-semibold"><%= user.username %></div>
      </div>

      <form method="POST" action="/logout" class="m-0">
        <button class="btn btn-ghost btn-sm">Logout</button>
      </form>
    <% } else { %>
      <a class="btn btn-accent btn-sm" href="/login">Login</a>
    <% } %>
  </div>
</div>