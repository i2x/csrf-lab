<div class="topbar">
    <div class="container-fluid py-2 px-3">
        <div class="topbar-inner d-flex align-items-center gap-3">

            <!-- left: title -->
            <div class="flex-grow-1">
                <div class="topbar-title">ระบบสารสนเทศเพื่องานทะเบียนนักศึกษา</div>
            </div>

            <!-- right -->
            <div class="topbar-actions">

                <!-- flag + lang -->
                <div class="lang-toggle" title="Language">
                    <i class="flag-icon flag-icon-th"></i>
                    <span class="text-muted fw-semibold">ไทย</span>
                </div>
                <!-- 🌙 Theme -->
                <button class="icon-btn" type="button" title="Theme">
                    <i data-feather="moon" class="ficon font-medium-5"></i>
                </button>

                <!-- 🔔 Notification -->
<a class="icon-btn position-relative notif-wrapper" href="/inbox" title="Inbox">
  <i data-feather="bell" class="ficon font-medium-5"></i>

  <% if (typeof unreadCount !== "undefined" && unreadCount > 0) { %>
    <span class="notif-label">
      <%= unreadCount > 99 ? "99+" : unreadCount %>
    </span>
  <% } %>
</a>


                <% if (user) { %>
                    <div class="userbox">

                        <div class="usertext">
                            <div class="name">
                                <%= user.username %>
                            </div>
                            <div class="role">นักศึกษา</div>
                        </div>

                        <div class="avatar" title="Profile">
                            <i data-feather="user" class="ficon"></i>
                            <span class="online"></span>
                        </div>

                        <form method="POST" action="/logout" class="m-0">
                            <button class="btn btn-teal btn-sm">ออกจากระบบ</button>
                        </form>

                    </div>
                    <% } else { %>
                        <a class="btn btn-teal btn-sm" href="/login">เข้าสู่ระบบ</a>
                        <% } %>

            </div>
        </div>
    </div>
</div>