<meta charset="utf-8" />
<meta name="viewport" content="width=device-width, initial-scale=1" />

<title><%= title || "RegLab Portal" %></title>

<link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css" rel="stylesheet">
<link rel="stylesheet"
 href="https://cdn.jsdelivr.net/npm/flag-icon-css@3.5.0/css/flag-icon.min.css">
<style>
  :root{
    --bg:#f3f6f8;
    --card:#ffffff;
    --line:#e7edf1;
    --text:#22313f;
    --muted:#6b7b88;
    --teal:#10b3a6;
    --teal-2:#0ea5a0;
    --teal-soft:#d9f6f2;
    --shadow: 0 10px 30px rgba(16, 24, 40, .08);
    --radius: 14px;
    --sidebar:#ffffff;
    --sidebar-line:#edf2f6;
    --sidebar-hover:#f3fbfa;
  }

  body{
    background: var(--bg);
    color: var(--text);
    min-height: 100vh;
  }

  .app-shell{
    display:grid;
    grid-template-columns: 280px minmax(0, 1fr);
    min-height: 100vh;
  }

  .sidebar{
    background: var(--sidebar);
    border-right: 1px solid var(--sidebar-line);
    padding: 18px 14px;
  }

  .topbar{
    background: #fff;
    border-bottom: 1px solid var(--line);
    box-shadow: 0 6px 18px rgba(16,24,40,.06);
  }

  .content{
    padding: 18px 22px;
  }

  .brand{
    display:flex;
    align-items:center;
    gap:10px;
    padding: 10px 10px 14px;
    border-bottom: 1px solid var(--sidebar-line);
    margin-bottom: 12px;
  }

  .brand-mark{
    width: 44px;
    height: 44px;
    border-radius: 10px;
    background: linear-gradient(135deg, var(--teal), #22c55e);
    display:grid;
    place-items:center;
    color:#fff;
    font-weight:800;
    letter-spacing:.5px;
    box-shadow: 0 10px 22px rgba(16,179,166,.25);
  }

  .brand-title{
    line-height: 1.1;
  }
  .brand-title .name{
    font-weight:800;
    font-size: 18px;
  }
  .brand-title .sub{
    color: var(--muted);
    font-size: 12px;
  }

  .nav-section-title{
    color: var(--muted);
    font-size: 12px;
    font-weight: 700;
    margin: 12px 10px 8px;
    text-transform: uppercase;
    letter-spacing: .08em;
  }

  .nav-item{
    display:flex;
    align-items:center;
    gap:12px;
    padding: 10px 12px;
    margin: 6px 6px;
    border-radius: 12px;
    color: var(--text);
    text-decoration:none;
    border: 1px solid transparent;
  }

  .nav-item:hover{
    background: var(--sidebar-hover);
    border-color: rgba(16,179,166,.18);
  }

  .nav-item.active{
    background: var(--teal-soft);
    border-color: rgba(16,179,166,.28);
    color: #0b6f69;
    font-weight: 700;
  }

  .nav-ico{
    width: 26px;
    height: 26px;
    border-radius: 10px;
    display:grid;
    place-items:center;
    background: #f3f6f8;
    border: 1px solid var(--sidebar-line);
  }

  .card-portal{
    background: var(--card);
    border: 1px solid var(--line);
    border-radius: var(--radius);
    box-shadow: var(--shadow);
  }

  .panel-header{
    background: linear-gradient(90deg, var(--teal), var(--teal-2));
    color: #fff;
    padding: 12px 16px;
    border-radius: calc(var(--radius) - 1px) calc(var(--radius) - 1px) 0 0;
    font-weight: 800;
    display:flex;
    align-items:center;
    gap:10px;
  }

  .panel-body{
    padding: 18px;
  }

  .btn-teal{
    background: var(--teal);
    color: #fff;
    border: none;
  }
  .btn-teal:hover{ background: var(--teal-2); color:#fff; }

  .btn-outline-teal{
    border: 1px solid rgba(16,179,166,.45);
    color: #0b6f69;
    background: #fff;
  }
  .btn-outline-teal:hover{
    background: var(--teal-soft);
    color: #0b6f69;
  }

  .form-control, .form-select{
    border-radius: 10px;
    border: 1px solid #dfe7ee;
    background: #fff;
  }

  .crumb{
    color: var(--muted);
    font-size: 13px;
  }
  .crumb a{ color: var(--teal-2); text-decoration:none; }
  .crumb a:hover{ text-decoration:underline; }

  /* Responsive */
  @media (max-width: 992px){
    .app-shell{ grid-template-columns: 1fr; }
    .sidebar{ display:none; }
    .content{ padding: 14px; }
  }

  /* ===== portal main look ===== */
.page-title{
  font-size: 28px;
  font-weight: 800;
  margin: 0;
}
.page-subcrumb{
  margin-top: 6px;
}

.kpi-banner{
  border: 1px solid rgba(16,179,166,.35);
  background: #fff;
  border-radius: var(--radius);
  padding: 18px;
  box-shadow: var(--shadow);
}

.kpi-banner .big{
  font-size: 36px;
  font-weight: 900;
  color: #22c55e;
  letter-spacing: .3px;
}

.content-block{
  background: #fff;
  border: 1px solid var(--line);
  border-radius: var(--radius);
  box-shadow: var(--shadow);
  padding: 18px;
}

.block-title{
  font-weight: 800;
  color: #22313f;
  margin-bottom: 12px;
}

.tab-pill{
  display:inline-flex;
  border: 1px solid rgba(16,179,166,.35);
  border-radius: 10px;
  overflow: hidden;
}
.tab-pill button{
  border: none;
  background: #fff;
  padding: 8px 16px;
  font-weight: 700;
  color: #0b6f69;
}
.tab-pill button.active{
  background: var(--teal-soft);
}

.table-portal thead th{
  background: #e9ecef;
  color: #334155;
  font-weight: 800;
  border-bottom: 1px solid #dbe3ea !important;
}
.table-portal td, .table-portal th{
  border-color: #e6edf3 !important;
}
.table-portal tfoot td{
  background: #f3f4f6;
  font-weight: 800;
}

.empty-state{
  display:grid;
  place-items:center;
  height: 240px;
  border-radius: var(--radius);
  border: 1px solid #e6edf3;
  background: #fff;
}
.empty-state .icon{
  width: 54px;
  height: 54px;
  border-radius: 999px;
  display:grid;
  place-items:center;
  border: 2px solid #ef4444;
  color:#ef4444;
  font-weight: 900;
  margin-bottom: 10px;
}
.empty-state .label{
  color:#b91c1c;
  font-weight: 800;
}

/* ===== topbar v2 ===== */
.topbar{
  background: transparent;
  border-bottom: 0;
  box-shadow: none;
}
.topbar-inner{
  background: #fff;
  border: 1px solid var(--line);
  border-radius: 14px;
  box-shadow: 0 10px 24px rgba(16,24,40,.10);
  padding: 12px 16px;
}
.topbar-title{
  font-weight: 900;
  font-size: 22px;
  color: #4b5563;
}
.topbar-actions{
  display:flex;
  align-items:center;
  gap: 10px;
}
.icon-btn{
  width: 38px;
  height: 38px;
  border-radius: 10px;
  display:grid;
  place-items:center;
  border: 1px solid var(--line);
  background: #fff;
  color: #64748b;
}
.icon-btn:hover{
  background: #f8fafc;
}
.flag-th{
  width: 22px;
  height: 14px;
  border-radius: 3px;
  border: 1px solid rgba(0,0,0,.08);
  overflow: hidden;
  display:inline-grid;
}
.flag-th span{ display:block; height: 20%; }
.flag-th .r{ background:#d90429; height: 20%; }
.flag-th .w{ background:#ffffff; height: 20%; }
.flag-th .b{ background:#0033a0; height: 40%; }

.userbox{
  display:flex;
  align-items:center;
  gap: 10px;
  margin-left: 6px;
}
.usertext{
  text-align:right;
  line-height: 1.1;
}
.usertext .name{
  font-weight: 900;
  color:#111827;
  white-space: nowrap;
}
.usertext .role{
  font-size: 12px;
  color: var(--muted);
}
.avatar{
  width: 44px;
  height: 44px;
  border-radius: 999px;
  background: #e5e7eb;
  border: 2px solid #fff;
  box-shadow: 0 8px 18px rgba(16,24,40,.12);
  position: relative;
  overflow: hidden;
  display:grid;
  place-items:center;
  font-weight:900;
  color:#6b7280;
}
.avatar .online{
  position:absolute;
  right: 4px;
  bottom: 4px;
  width: 10px;
  height: 10px;
  border-radius: 999px;
  background: #22c55e;
  border: 2px solid #fff;
}

.flag-icon{
  width: 22px;
  height: 16px;
  border-radius: 3px;
  box-shadow: 0 0 0 1px rgba(0,0,0,.06);
}
.lang-toggle{
  display:flex;
  align-items:center;
  gap:8px;
  padding: 6px 8px;
  border-radius: 10px;
  border: 1px solid var(--line);
  background: #fff;
}
.lang-toggle:hover{
  background:#f8fafc;
}
</style>


<script src="https://unpkg.com/feather-icons"></script>
