<meta charset="utf-8" />
<meta name="viewport" content="width=device-width, initial-scale=1" />

<title><%= title || "CSRF Lab" %></title>

<link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css" rel="stylesheet">

<style>
  :root{
    --bg0:#0b1220;
    --bg1:#0f172a;
    --card: rgba(30,41,59,.72);
    --card2: rgba(17,24,39,.75);
    --border: rgba(148,163,184,.16);
    --text:#e5e7eb;
    --muted:#94a3b8;
    --accent:#6366f1;
    --accent2:#3b82f6;
    --danger:#ef4444;
    --warn:#f59e0b;
    --good:#22c55e;
  }

  body{
    background: radial-gradient(1100px 700px at 15% 10%, #1f2a44 0%, var(--bg1) 35%, var(--bg0) 100%);
    color: var(--text);
    min-height: 100vh;
  }

  /* text readability */
  h1,h2,h3,h4,h5{ color: #f1f5f9; }
  .text-muted{ color: var(--muted)!important; }

  /* layout shell */
  .app-shell{
    display: grid;
    grid-template-columns: 260px minmax(0, 1fr);
    grid-template-rows: 64px minmax(0, 1fr);
    grid-template-areas:
      "sidebar topbar"
      "sidebar main";
    min-height: 100vh;
  }

  .app-topbar{
    grid-area: topbar;
    background: rgba(17,24,39,.65);
    backdrop-filter: blur(10px);
    border-bottom: 1px solid var(--border);
  }

  .app-sidebar{
    grid-area: sidebar;
    background: rgba(15,23,42,.75);
    backdrop-filter: blur(10px);
    border-right: 1px solid var(--border);
  }

  .app-main{
    grid-area: main;
    padding: 18px;
  }

  /* cards */
  .card-glass{
    background: var(--card);
    border: 1px solid var(--border);
    border-radius: 16px;
    backdrop-filter: blur(12px);
    box-shadow: 0 10px 30px rgba(0,0,0,.25);
  }

  .card-soft{
    background: var(--card2);
    border: 1px solid var(--border);
    border-radius: 16px;
  }

  .form-control, .form-select{
    background: rgba(2,6,23,.75);
    border: 1px solid rgba(148,163,184,.22);
    color: var(--text);
  }
  .form-control:focus, .form-select:focus{
    background: rgba(2,6,23,.85);
    border-color: rgba(99,102,241,.75);
    box-shadow: 0 0 0 .2rem rgba(99,102,241,.18);
    color: var(--text);
  }

  .btn-accent{
    background: linear-gradient(90deg, var(--accent2), var(--accent));
    border: none;
    color: white;
  }
  .btn-accent:hover{ opacity: .92; }

  .btn-ghost{
    border: 1px solid rgba(148,163,184,.22);
    color: var(--text);
    background: rgba(2,6,23,.25);
  }
  .btn-ghost:hover{
    background: rgba(2,6,23,.45);
    border-color: rgba(148,163,184,.35);
  }

  .badge-dot{
    display:inline-flex;
    align-items:center;
    gap:8px;
  }
  .dot{
    width:8px;height:8px;border-radius:99px;
    background: var(--good);
    box-shadow: 0 0 14px rgba(34,197,94,.6);
  }

  /* sidebar */
  .brand{
    font-weight: 700;
    letter-spacing: .3px;
  }
  .nav-pill{
    display:flex;
    align-items:center;
    gap:10px;
    padding: 10px 12px;
    border-radius: 12px;
    color: var(--text);
    text-decoration:none;
    border: 1px solid transparent;
  }
  .nav-pill:hover{
    background: rgba(2,6,23,.35);
    border-color: rgba(148,163,184,.16);
  }
  .nav-pill.active{
    background: rgba(99,102,241,.16);
    border-color: rgba(99,102,241,.35);
  }

  /* responsive */
  @media (max-width: 992px){
    .app-shell{
      grid-template-columns: 1fr;
      grid-template-areas:
        "topbar"
        "main";
    }
    .app-sidebar{ display:none; }
    .app-main{ padding: 14px; }
  }
</style>