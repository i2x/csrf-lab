<!doctype html>
<html>
<head>
  <meta charset="utf-8" />
  <title>Login</title>

  <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css" rel="stylesheet">

  <style>
    body {
      background: radial-gradient(circle at 20% 20%, #1e293b, #0f172a);
      min-height: 100vh;
      color: #e2e8f0;
    }

    .card-glass {
      background: rgba(30, 41, 59, 0.6);
      backdrop-filter: blur(12px);
      border: 1px solid rgba(255,255,255,0.05);
      box-shadow: 0 0 30px rgba(59,130,246,0.15);
      border-radius: 16px;
    }

    .form-control {
      background: #0f172a;
      border: 1px solid #334155;
      color: #e2e8f0;
    }

    .form-control:focus {
      background: #0f172a;
      border-color: #3b82f6;
      box-shadow: 0 0 0 0.2rem rgba(59,130,246,.25);
      color: white;
    }

    .btn-primary {
      background: linear-gradient(90deg, #3b82f6, #6366f1);
      border: none;
    }

    .btn-primary:hover {
      opacity: 0.9;
    }

    .eye-btn {
      background: #1e293b;
      border: 1px solid #334155;
      color: #94a3b8;
    }
  </style>
</head>

<body class="d-flex justify-content-center align-items-center">

<div class="card card-glass p-4" style="width: 420px;">

  <h3 class="text-center mb-4">🔐 Secure Login</h3>

  <% if (error) { %>
    <div class="alert alert-danger py-2"><%= error %></div>
  <% } %>

  <form method="POST" action="/login">

    <div class="mb-3">
      <label class="form-label text-secondary">Username</label>
      <input name="username" class="form-control" value="alice" required>
    </div>

    <div class="mb-4">
      <label class="form-label text-secondary">Password</label>
      <div class="input-group">
        <input type="password" name="password" id="password"
               class="form-control" value="password123" required>
        <button class="btn eye-btn" type="button"
                onclick="togglePassword('password')">
          👁
        </button>
      </div>
    </div>

    <button class="btn btn-primary w-100 py-2">
      Sign In
    </button>

  </form>
</div>

<script>
function togglePassword(id){
  const input = document.getElementById(id);
  input.type = input.type === "password" ? "text" : "password";
}
</script>

</body>
</html>