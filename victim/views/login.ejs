<!doctype html>
<html>
<head>
  <%- include("partials/head", { title: "เข้าสู่ระบบ - RegLab" }) %>
</head>
<body>
  <div class="app-shell">
    <%- include("partials/sidebar", { active: "login", user }) %>

    <div>
      <%- include("partials/topbar", { user }) %>

      <div class="content">
        <div class="d-flex align-items-center justify-content-between mb-3">
          <div>
            <h3 class="mb-0">เข้าสู่ระบบ</h3>
            <div class="crumb mt-1">
              <a href="/login">หน้าแรก</a> &nbsp;›&nbsp; เข้าสู่ระบบ
            </div>
          </div>
        </div>

        <div class="d-flex justify-content-center">
          <div class="card-portal" style="width: 760px; max-width: 100%;">
            <div class="panel-header">
              <span style="font-size:18px;">⤿</span>
              <span>กรุณาป้อนบัญชีผู้ใช้และรหัสผ่าน</span>
            </div>

            <div class="panel-body">
              <% if (error) { %>
                <div class="alert alert-danger py-2 mb-3"><%= error %></div>
              <% } %>

              <form method="POST" action="/login" class="mx-auto" style="max-width: 420px;">
                <div class="mb-3">
                  <label class="form-label">Account</label>
                  <input name="username" class="form-control" value="" required>
                </div>

                <div class="mb-3">
                  <label class="form-label">รหัสผ่าน</label>
                  <div class="input-group">
                    <input type="password" name="password" id="password" class="form-control" value="" required>
                    <button class="btn btn-outline-secondary" type="button" onclick="togglePassword('password')">👁</button>
                  </div>
                </div>

                <button class="btn btn-teal w-100 py-2">เข้าสู่ระบบ</button>

                <div class="mt-3 small">
                  <a href="#" class="text-decoration-none" style="color: var(--teal-2);">เปิดบัญชี</a>
                  <span class="text-muted"> • </span>
                  <a href="#" class="text-decoration-none" style="color: var(--teal-2);">ลืมรหัสผ่าน</a>
                  <span class="text-muted"> • </span>
                  <a href="#" class="text-decoration-none" style="color: var(--teal-2);">คู่มือการใช้งาน</a>
                </div>
              </form>
            </div>
          </div>
        </div>

        <div class="text-center text-muted small mt-4">© 2026 RegLab (Educational)</div>
      </div>
    </div>
  </div>

  <%- include("partials/scripts") %>
</body>
</html>