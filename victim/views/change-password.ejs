<!doctype html>
<html>
<head>
  <%- include("partials/head", { title: "Change Password - CSRF Lab" }) %>
</head>

<body>
  <div class="app-shell">
    <%- include("partials/sidebar", { active: "change", user }) %>
    <%- include("partials/topbar", { user }) %>

    <main class="app-main">
      <div class="mb-3">
        <h4 class="mb-1">Change Password</h4>
        <div class="text-muted">Unsafe GET endpoint for CSRF demonstration</div>
      </div>

      <div class="row g-3">
        <div class="col-12 col-lg-6">
          <div class="card-glass p-3">
            <% if (error) { %>
              <div class="alert alert-danger py-2"><%= error %></div>
            <% } %>

            <% if (success) { %>
              <div class="alert alert-success py-2"><%= success %></div>
            <% } %>

            <form method="GET" action="/change-password-unsafe">
              <div class="mb-3">
                <label class="form-label text-muted">New Password</label>
                <div class="input-group">
                  <input type="password" name="newPassword" id="newPassword" class="form-control" required>
                  <button class="btn btn-ghost" type="button" onclick="togglePassword('newPassword')">👁</button>
                </div>
                <div class="text-muted small mt-2">
                  Endpoint: <span class="text-muted">/change-password-unsafe?newPassword=...</span>
                </div>
              </div>

              <button class="btn btn-accent w-100">Change (Unsafe GET)</button>
            </form>
          </div>
        </div>

        <div class="col-12 col-lg-6">
          <div class="card-soft p-3">
            <div class="fw-semibold mb-2">How to reproduce CSRF</div>
            <ol class="text-muted small mb-0">
              <li>Login ที่ victim ให้ session ติด</li>
              <li>เปิด attacker page (อีก origin)</li>
              <li>หน้า attacker จะยิง GET มาที่ <code class="text-muted">/change-password-unsafe</code></li>
              <li>ลอง logout แล้ว login ด้วยรหัสใหม่</li>
            </ol>
          </div>
        </div>
      </div>
    </main>
  </div>

  <%- include("partials/scripts") %>
</body>
</html>