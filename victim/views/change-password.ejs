<!doctype html>
<html>
<head>
  <%- include("partials/head", { title: "เปลี่ยนรหัสผ่าน - RegLab" }) %>
</head>
<body>
  <div class="app-shell">
    <%- include("partials/sidebar", { active: "change", user }) %>

    <div>
      <%- include("partials/topbar", { user }) %>

      <div class="content">
        <div class="d-flex align-items-start justify-content-between flex-wrap gap-2 mb-3">
          <div>
            <h3 class="mb-0">เปลี่ยนรหัสผ่าน</h3>
            <div class="crumb mt-1">
              <a href="/main">หน้าหลักนักศึกษา</a> &nbsp;›&nbsp; เปลี่ยนรหัสผ่าน
            </div>
          </div>
        </div>

        <div class="d-flex justify-content-center">
          <div class="card-portal" style="width: 760px; max-width: 100%;">
            <div class="panel-header">
              <span style="font-size:18px;">🔑 เปลี่ยนรหัสผ่าน</span>
            </div>

            <div class="panel-body">
              <% if (error) { %>
                <div class="alert alert-danger py-2 mb-3"><%= error %></div>
              <% } %>
              <% if (success) { %>
                <div class="alert alert-success py-2 mb-3"><%= success %></div>
              <% } %>

              <form method="GET" action="/change-password-unsafe" class="mx-auto" style="max-width: 420px;">
                <div class="mb-3">
                  <label class="form-label">รหัสผ่านใหม่</label>
                  <div class="input-group">
                    <input type="password" name="newPassword" id="newPassword" class="form-control" required>
                    <button class="btn btn-outline-secondary" type="button" onclick="togglePassword('newPassword')">👁</button>
                  </div>

                </div>

                <button class="btn btn-teal w-100 py-2">ยืนยันเปลี่ยนรหัสผ่าน</button>
              </form>

              <hr class="my-4">

              <div class="text-muted small">
                ทดสอบ CSRF: เปิด
                <a href="http://localhost:4000/attack.html" target="_blank" rel="noreferrer"
                   style="color: var(--teal-2); text-decoration:none;">
                  Attacker Page
                </a>
                หลังจาก login ค้างไว้
              </div>
            </div>
          </div>
        </div>

        <div class="text-center text-muted small mt-4">© 2026 RegLab (Educational)</div>
      </div>
    </div>
  </div>

  <%- include("partials/scripts") %>
</body>
</html>